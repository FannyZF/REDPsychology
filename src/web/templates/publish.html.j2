{% extends "base.html.j2" %}
{% block content %}
<h2 class="text-lg font-semibold text-gray-800 mb-6">发布管理</h2>

<div class="grid grid-cols-2 gap-6">
<div>
<h3 class="font-semibold text-gray-700 mb-4">待发布队列 ({{ queue|length }})</h3>
{% if queue %}
<div class="space-y-3">
{% for item in queue %}
<div class="card p-4">
  <div class="flex items-center gap-2 mb-2">
    {% if item.get('video_path') %}
    <span class="pill bg-purple-100 text-purple-600">视频</span>
    {% else %}
    <span class="pill bg-blue-100 text-blue-600">图文</span>
    {% endif %}
    <span class="pill bg-yellow-100 text-yellow-700">{{ item.get('priority', '') }}</span>
  </div>
  <p class="text-sm font-medium text-gray-700 mb-2">{{ item.get('xhs_title', item.get('title', ''))[:50] }}</p>
  
  <div class="bg-gray-50 rounded-lg p-3 mb-3">
    <p class="text-xs text-gray-500 mb-1">标题</p>
    <p class="text-sm text-gray-800 mb-2">{{ item.get('xhs_title', '') }}</p>
    <div class="flex gap-1 flex-wrap">
      {% set tags = item.get('xhs_tags', '[]') %}
      {% if tags is string %}{% set tags = [] %}{% endif %}
      {% if tags is not string and tags %}
      {% for t in tags[:8] %}<span class="pill bg-pink-50 text-pink-500 text-xs">#{{ t }}</span>{% endfor %}
      {% endif %}
    </div>
  </div>

  <div class="flex gap-2">
    <a href="/api/content/{{ item.id }}/video" download class="btn bg-purple-500 text-white text-xs">下载视频</a>
    <button onclick="copyText('{{ item.id }}')" class="btn bg-gray-100 text-xs">复制文案</button>
    <button onclick="markPublished('{{ item.id }}')" class="btn bg-green-500 text-white text-xs">标记已发布</button>
  </div>
</div>
{% endfor %}
</div>
{% else %}
<div class="card p-8 text-center text-gray-400">暂无待发布内容</div>
{% endif %}
</div>

<div>
<h3 class="font-semibold text-gray-700 mb-4">发布历史 (最近20条)</h3>
{% if published %}
<div class="space-y-3">
{% for item in published %}
<div class="card p-4">
  <div class="flex items-center gap-2 mb-1">
    <span class="pill bg-green-100 text-green-600">已发布</span>
    <span class="text-xs text-gray-400">{{ item.get('xhs_published_at', '')[:16] }}</span>
  </div>
  <p class="text-sm text-gray-600 truncate">{{ item.get('xhs_title', item.get('title', ''))[:50] }}</p>
</div>
{% endfor %}
</div>
{% else %}
<div class="card p-8 text-center text-gray-400">暂无发布记录</div>
{% endif %}
</div>
</div>

<script>
async function markPublished(id) {
  await fetch('/api/publish/'+id, {method:'POST'});
  location.reload();
}
async function copyText(id) {
  const resp = await fetch('/api/content');
  const data = await resp.json();
  const item = data.items.find(i => i.id === id);
  if (item) {
    const tags = JSON.parse(item.xhs_tags || '[]');
    const text = item.xhs_title + '\n\n' + item.xhs_content + '\n\n' + tags.map(t=>'#'+t).join(' ');
    await navigator.clipboard.writeText(text);
    alert('文案已复制');
  }
}
</script>
{% endblock %}
