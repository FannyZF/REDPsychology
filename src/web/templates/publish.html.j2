{% extends "base.html.j2" %}
{% block content %}
<h2 class="text-lg font-semibold text-gray-800 mb-6">发布管理</h2>

<div class="grid grid-cols-2 gap-6">
<div>
<h3 class="font-semibold text-gray-700 mb-4">待发布队列 ({{ queue|length }})</h3>
{% if queue %}
<div class="space-y-3">
{% for item in queue %}
<div class="card p-4">
  <div class="flex items-center gap-2 mb-2">
    {% if item.get('video_path', '').endswith('.png') %}
    <span class="pill bg-blue-100 text-blue-600">图文</span>
    <a href="/api/content/{{ item.id }}/video" download class="btn bg-blue-500 text-white text-xs">下载封面图</a>
    {% elif item.get('video_path') %}
    <span class="pill bg-purple-100 text-purple-600">视频</span>
    <a href="/api/content/{{ item.id }}/video" download class="btn bg-purple-500 text-white text-xs">下载视频</a>
    {% else %}
    <span class="pill bg-blue-100 text-blue-600">图文</span>
    {% endif %}
    <span class="pill bg-yellow-100 text-yellow-700">{{ item.get('priority', '') }}</span>
  </div>
  <p class="text-sm font-medium text-gray-700 mb-2">{{ item.get('xhs_title', item.get('title', ''))[:50] }}</p>
  
  <div class="bg-gray-50 rounded-lg p-3 mb-3">
    <div class="flex justify-between items-center mb-2">
      <p class="text-xs text-gray-500">发布文案预览</p>
      <button onclick="copyText('{{ item.id }}')" class="btn bg-blue-500 text-white text-xs">复制文案</button>
    </div>
    <div class="bg-white rounded p-3 text-sm text-gray-800 whitespace-pre-wrap" style="max-height:200px; overflow-y:auto">
      <p class="font-semibold mb-2">{{ item.get('xhs_title', '') }}</p>
      <p class="mb-2">{{ item.get('xhs_content', '').replace('\\n', '
').replace('\n', '
') }}</p>
      <p class="text-pink-600">
        {% set tags = item.get('xhs_tags', '[]') %}
        {% if tags is string %}{% set tag_list = tags %}{% else %}{% set tag_list = '[]' %}{% endif %}
        {% set ns = namespace(parsed=[]) %}
        {% if tag_list %}
          {% for t in tag_list[:8] if t %}#{{ t }} {% endfor %}
        {% endif %}
      </p>
    </div>
  </div>

  <div class="flex gap-2">
    {% if item.get('video_path', '').endswith('.png') %}
    <a href="/api/content/{{ item.id }}/video" download class="btn bg-blue-500 text-white text-xs">下载封面图</a>
    {% else %}
    <a href="/api/content/{{ item.id }}/video" download class="btn bg-purple-500 text-white text-xs">下载视频</a>
    {% endif %}
    <button onclick="copyText('{{ item.id }}')" class="btn bg-gray-100 text-xs">复制文案</button>
    <button onclick="wechatPublish('{{ item.id }}')" class="btn bg-green-500 text-white text-xs" id="wx-btn-{{ item.id }}">发布公众号</button>
    <button onclick="markPublished('{{ item.id }}')" class="btn bg-gray-100 text-xs">标记已发布</button>
  </div>
</div>
{% endfor %}
</div>
{% else %}
<div class="card p-8 text-center text-gray-400">暂无待发布内容</div>
{% endif %}
</div>

<div>
<h3 class="font-semibold text-gray-700 mb-4">发布历史 (最近20条)</h3>
{% if published %}
<div class="space-y-3">
{% for item in published %}
<div class="card p-4">
  <div class="flex items-center gap-2 mb-1">
    <span class="pill bg-green-100 text-green-600">已发布</span>
    <span class="text-xs text-gray-400">{{ item.get('xhs_published_at', '')[:16] }}</span>
  </div>
  <p class="text-sm text-gray-600 truncate">{{ item.get('xhs_title', item.get('title', ''))[:50] }}</p>
</div>
{% endfor %}
</div>
{% else %}
<div class="card p-8 text-center text-gray-400">暂无发布记录</div>
{% endif %}
</div>
</div>

<script>
async function markPublished(id) {
  await fetch('/api/publish/'+id, {method:'POST'});
  location.reload();
}
async function wechatPublish(id) {
  if (!confirm('确认发布到微信公众号？')) return;
  const btn = document.getElementById('wx-btn-'+id);
  btn.disabled = true;
  btn.textContent = '发布中...';
  try {
    const resp = await fetch('/api/publish/wechat/'+id, {method:'POST'});
    const data = await resp.json();
    if (data.status === 'published') {
      alert('公众号发布成功!');
      location.reload();
    } else {
      alert('发布失败: ' + (data.error || '未知错误'));
    }
  } catch(e) {
    alert('请求失败: ' + e.message);
  }
  btn.disabled = false;
  btn.textContent = '发布公众号';
}
async function copyText(id) {
  const resp = await fetch('/api/content');
  const data = await resp.json();
  const item = data.items.find(i => i.id === id);
  if (!item) return;

  const tags = (() => { try { return JSON.parse(item.xhs_tags || '[]'); } catch(e) { return []; } })();
  // Format for Xiaohongshu: single newlines between paragraphs, tags at end
  const title = (item.xhs_title || '').trim();
  const body = (item.xhs_content || '').replace(/\\n/g, '\n').replace(/\n{3,}/g, '\n\n').trim();
  const tagLine = tags.map(t => '#' + t).join(' ');
  const text = title + '\n\n' + body + '\n\n' + tagLine;

  // Fallback copy method (works on HTTP)
  const ta = document.createElement('textarea');
  ta.value = text;
  ta.style.position = 'fixed';
  ta.style.left = '-9999px';
  document.body.appendChild(ta);
  ta.select();
  try {
    document.execCommand('copy');
    alert('文案已复制，打开小红书粘贴即可');
  } catch(e) {
    alert('复制失败，请手动选择复制');
  }
  document.body.removeChild(ta);
}
</script>
{% endblock %}
