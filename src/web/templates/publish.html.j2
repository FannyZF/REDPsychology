{% extends "base.html.j2" %}
{% block content %}
<h2 class="text-lg font-semibold text-gray-800 mb-6">发布管理</h2>

<div class="grid grid-cols-2 gap-6">
<div>
<h3 class="font-semibold text-gray-700 mb-4">待发布队列 ({{ queue|length }})</h3>
{% if queue %}
<div class="space-y-3">
{% for item in queue %}
<div class="card p-4">
  <div class="flex items-center gap-2 mb-2">
    {% if item.get('video_path', '').endswith('.png') %}
    <span class="pill bg-blue-100 text-blue-600">图文</span>
    {% elif item.get('video_path') %}
    <span class="pill bg-purple-100 text-purple-600">视频</span>
    {% else %}
    <span class="pill bg-blue-100 text-blue-600">图文</span>
    {% endif %}
    <span class="pill bg-yellow-100 text-yellow-700">{{ item.get('priority', '') }}</span>
    <span class="text-xs text-gray-400">预定发布</span>
    <input type="datetime-local" value="{{ item.get('scheduled_time', '') }}" 
           data-id="{{ item.id }}"
           class="border rounded-lg px-2 py-1 text-xs w-44">
  </div>
  <p class="text-sm font-medium text-gray-700 mb-2">{{ item.get('xhs_title', item.get('title', ''))[:50] }}</p>
  
  <div class="bg-gray-50 rounded-lg p-3 mb-3">
    <p class="text-xs text-gray-500 mb-1">发布文案</p>
    <div class="bg-white rounded p-3 text-sm text-gray-800 whitespace-pre-wrap max-h-32 overflow-y-auto">
      <p class="font-semibold mb-1">{{ item.get('xhs_title', '') }}</p>
      <p class="mb-1 text-xs">{{ item.get('xhs_content', '')[:150] }}{% if item.get('xhs_content', '')|length > 150 %}...{% endif %}</p>
    </div>
  </div>

  <div class="flex gap-2 flex-wrap">
    {% if item.get('video_path', '').endswith('.png') %}
    <a href="/api/content/{{ item.id }}/video" download class="btn bg-blue-500 text-white text-xs">下载封面</a>
    {% else %}
    <a href="/api/content/{{ item.id }}/video" download class="btn bg-purple-500 text-white text-xs">下载视频</a>
    {% endif %}
    <button onclick="copyText('{{ item.id }}')" class="btn bg-gray-100 text-xs">复制文案</button>
    <button onclick="publishWechat('{{ item.id }}')" class="btn bg-green-500 text-white text-xs">发布公众号</button>
    <button onclick="markXHS('{{ item.id }}')" class="btn bg-rose-500 text-white text-xs">已发小红书</button>
    <button onclick="saveSchedule('{{ item.id }}')" class="btn bg-orange-500 text-white text-xs">定时发送</button>
  </div>
</div>
{% endfor %}
</div>
{% else %}
<div class="card p-8 text-center text-gray-400">暂无待发布内容</div>
{% endif %}
</div>

<div>
<h3 class="font-semibold text-gray-700 mb-4">发布历史 (最近20条)</h3>
{% if published %}
<div class="space-y-3">
{% for item in published %}
<div class="card p-4">
  <div class="flex items-center gap-2 mb-1">
    {% set platform = item.get('publish_platform', '') %}
    {% if 'wechat' in platform %}<span class="pill bg-green-100 text-green-600">公众号</span>{% endif %}
    {% if 'xhs' in platform %}<span class="pill bg-rose-100 text-rose-600">小红书</span>{% endif %}
    {% if not platform %}<span class="pill bg-green-100 text-green-600">已发布</span>{% endif %}
    <span class="text-xs text-gray-400">{{ item.get('xhs_published_at', '')[:16] }}</span>
  </div>
  <p class="text-sm text-gray-600 truncate">{{ item.get('xhs_title', item.get('title', ''))[:50] }}</p>
</div>
{% endfor %}
</div>
{% else %}
<div class="card p-8 text-center text-gray-400">暂无发布记录</div>
{% endif %}
</div>
</div>

<script>
async function publishWechat(id) {
  if (!confirm('确认发布到公众号？')) return;
  try {
    const resp = await fetch('/api/publish/wechat/'+id, {method:'POST'});
    const data = await resp.json();
    if (data.status === 'published') {
      if (data.message) {
        alert('草稿已生成! 请在订阅号助手App中手动发布');
      } else {
        alert('发布成功!');
      }
      location.reload();
    } else {
      alert('失败: ' + (data.error || data.detail || '未知'));
    }
  } catch(e) {
    alert('请求失败: ' + e.message);
  }
}

async function markXHS(id) {
  if (!confirm('确认标记为已发送到小红书？')) return;
  await fetch('/api/publish/mark-xhs/'+id, {method:'POST'});
  location.reload();
}

async function saveSchedule(id) {
  const input = document.querySelector(`input[data-id="${id}"]`);
  const time = input ? input.value : '';
  if (!time) { alert('请先选择发布时间'); return; }
  await fetch('/api/content/'+id+'/schedule-time', {
    method:'PUT', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({time: time})
  });
  alert('已设定定时发送: ' + time);
}

async function markPublished(id) {
  await fetch('/api/publish/'+id, {method:'POST'});
  location.reload();
}
async function copyText(id) {
  const resp = await fetch('/api/content?limit=200');
  const data = await resp.json();
  const item = data.items.find(i => i.id === id);
  if (!item) { alert('未找到该内容'); return; }
  const tags = (() => { try { return JSON.parse(item.xhs_tags || '[]'); } catch(e) { return []; } })();
  const title = (item.xhs_title || '').trim();
  const body = (item.xhs_content || '').replace(/\\n/g, '\n').replace(/\n{3,}/g, '\n\n').trim();
  const tagLine = tags.map(t => '#' + t).join(' ');
  const text = title + '\n\n' + body + '\n\n' + tagLine;

  try {
    await navigator.clipboard.writeText(text);
    alert('文案已复制到剪贴板');
    return;
  } catch(e) {}

  const ta = document.createElement('textarea');
  ta.value = text; ta.style.position = 'fixed'; ta.style.left = '0'; ta.style.top = '0';
  ta.style.width = '80%'; ta.style.height = '200px'; ta.style.zIndex = '9999';
  document.body.appendChild(ta);
  ta.focus(); ta.select();
  try { document.execCommand('copy'); alert('文案已复制'); document.body.removeChild(ta); return; } catch(e) {}
  alert('自动复制失败，文本已选中，请手动 Ctrl+C 复制');
}
async function setTime(id, time) {
  await fetch('/api/content/'+id+'/schedule-time', {
    method:'PUT', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({time: time})
  });
}
</script>
{% endblock %}
