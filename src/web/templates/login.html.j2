{% extends "base.html.j2" %}
{% block content %}
<div class="max-w-lg mx-auto text-center">
  <h2 class="text-xl font-bold text-gray-800 mb-2">小红书登录</h2>
  <p class="text-gray-500 mb-6">点击下方按钮，在新标签页查看二维码，用小红书 App 扫码</p>

  <div class="card p-6 mb-6">
    <button onclick="captureQR()" class="btn bg-orange-500 text-white text-lg w-full mb-4" id="capture-btn">1. 获取登录二维码</button>
    <p id="capture-status" class="text-sm text-gray-400 hidden"></p>
    <a id="qr-link" href="#" target="_blank" class="btn bg-blue-500 text-white w-full hidden">2. 打开二维码 (新标签页)</a>
  </div>

  <div class="card p-6">
    <h3 class="font-semibold text-gray-700 mb-3">登录状态</h3>
    <div id="check-result" class="text-sm text-gray-400">扫码完成后点击下方检测</div>
    <button onclick="checkLogin()" class="btn bg-gray-100 text-sm mt-3">检测登录状态</button>
  </div>

  <p class="text-xs text-gray-400 mt-6">登录态保存在 Cookie 中，重启后无需重复登录</p>
</div>

<script>
async function captureQR() {
  document.getElementById('capture-btn').disabled = true;
  document.getElementById('capture-btn').textContent = '正在获取...';
  document.getElementById('capture-status').classList.remove('hidden');
  document.getElementById('capture-status').textContent = '正在打开小红书登录页...';
  
  await fetch('/api/login/qrcode', {method:'POST'});
  
  document.getElementById('capture-status').textContent = '二维码已获取，点击下方按钮查看';
  document.getElementById('qr-link').classList.remove('hidden');
  document.getElementById('capture-btn').textContent = '重新获取';
  document.getElementById('capture-btn').disabled = false;
  document.getElementById('qr-link').href = '/api/login/qrcode-image?t='+Date.now();
}

async function checkLogin() {
  const el = document.getElementById('check-result');
  el.textContent = '检测中...';
  try {
    const resp = await fetch('/api/login/check');
    const data = await resp.json();
    if (data.logged_in) {
      el.textContent = '已登录! 可以发布内容。';
      el.className = 'text-sm text-green-500';
    } else {
      el.textContent = '未登录，请扫码后再次检测';
      el.className = 'text-sm text-orange-500';
    }
  } catch(e) {
    el.textContent = '检测失败: ' + e.message;
    el.className = 'text-sm text-red-500';
  }
}
</script>
{% endblock %}
