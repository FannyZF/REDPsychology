{% extends "base.html.j2" %}
{% block content %}
<div class="max-w-lg mx-auto text-center">
  <h2 class="text-xl font-bold text-gray-800 mb-2">小红书登录</h2>
  <p class="text-gray-500 mb-6">首次使用需要扫码登录，已登录过则自动跳过</p>

  <div class="card p-6 mb-6">
    <button onclick="captureQR()" class="btn bg-orange-500 text-white text-lg w-full mb-4" id="capture-btn">获取登录二维码</button>
    <div id="qr-container" class="hidden">
      <p class="text-sm text-gray-500 mb-3">请用小红书 App 扫描下方二维码</p>
      <img id="qr-image" src="" class="mx-auto rounded-xl shadow-lg" style="max-width:300px">
      <div id="login-status" class="mt-4 text-sm text-green-500 hidden">正在检测登录状态...</div>
    </div>
  </div>

  <div class="card p-6">
    <h3 class="font-semibold text-gray-700 mb-3">已登录状态</h3>
    <div id="check-result" class="text-sm text-gray-400">点击下方检测</div>
    <button onclick="checkLogin()" class="btn bg-gray-100 text-sm mt-3">检测登录状态</button>
  </div>

  <p class="text-xs text-gray-400 mt-6">登录态保存在 Cookie 中，重启后无需重复登录</p>
</div>

<script>
async function captureQR() {
  document.getElementById('capture-btn').disabled = true;
  document.getElementById('capture-btn').textContent = '正在获取...';
  await fetch('/api/login/qrcode', {method:'POST'});
  setTimeout(() => {
    document.getElementById('qr-container').classList.remove('hidden');
    document.getElementById('qr-image').src = '/api/login/qrcode-image?t='+Date.now();
    document.getElementById('capture-btn').textContent = '刷新二维码';
    document.getElementById('capture-btn').disabled = false;
    pollLogin();
  }, 3000);
}

async function pollLogin() {
  const el = document.getElementById('login-status');
  el.classList.remove('hidden');
  for (let i = 0; i < 60; i++) {
    await new Promise(r => setTimeout(r, 2000));
    try {
      const resp = await fetch('/api/stats');
      if (resp.ok) {
        el.textContent = '登录成功! 3秒后跳转...';
        setTimeout(() => location.href = '/', 3000);
        return;
      }
    } catch(e) {}
    el.textContent = '等待扫码中... (' + ((i+1)*2) + 's)';
  }
  el.textContent = '超时，请重新获取二维码';
}

async function checkLogin() {
  const el = document.getElementById('check-result');
  el.textContent = '检测中...';
  try {
    const resp = await fetch('/api/stats');
    if (resp.ok) {
      el.textContent = '已登录! 可以发布内容。';
      el.className = 'text-sm text-green-500';
    }
  } catch(e) {
    el.textContent = '未登录，请先获取二维码扫码';
    el.className = 'text-sm text-orange-500';
  }
}
</script>
{% endblock %}
