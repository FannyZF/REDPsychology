<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>心语视界 - 管理后台</title>
<script src="https://cdn.jsdelivr.net/npm/tailwindcss@3"></script>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f5f5f7; }
  .glass { background: rgba(255,255,255,0.8); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); }
  .card { background: #fff; border-radius: 18px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); transition: all 0.2s; }
  .card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.1); transform: translateY(-2px); }
  .pill { border-radius: 20px; padding: 3px 14px; font-size: 13px; font-weight: 500; }
  .btn { border-radius: 12px; padding: 8px 20px; font-weight: 600; font-size: 14px; transition: all 0.15s; }
  .btn:hover { transform: scale(1.02); }
  .nav-link { padding: 8px 18px; border-radius: 10px; font-weight: 500; transition: all 0.15s; }
  .nav-link:hover, .nav-link.active { background: #f0f0f5; }
  .stat-card { background: #fff; border-radius: 18px; padding: 24px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
</style>
</head>
<body>
<nav class="glass sticky top-0 z-50 border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-gray-800">心语视界</a>
    <div class="flex gap-1">
      <a href="/" class="nav-link text-sm text-gray-600 {% if request and request.url and request.url.path == '/' %}active{% endif %}">看板</a>
      <a href="/content" class="nav-link text-sm text-gray-600 {% if request and request.url and request.url.path.startswith('/content') %}active{% endif %}">内容</a>
      <a href="/sources" class="nav-link text-sm text-gray-600 {% if request and request.url and request.url.path == '/sources' %}active{% endif %}">信源</a>
      <a href="/video" class="nav-link text-sm text-gray-600 {% if request and request.url and request.url.path == '/video' %}active{% endif %}">视频</a>
      <a href="/publish" class="nav-link text-sm text-gray-600 {% if request and request.url and request.url.path == '/publish' %}active{% endif %}">发布</a>
      <a href="/settings" class="nav-link text-sm text-gray-600 {% if request and request.url and request.url.path == '/settings' %}active{% endif %}">设置</a>
    </div>
  </div>
</nav>
<main class="max-w-6xl mx-auto px-6 py-8">
{% block content %}{% endblock %}
</main>
<script>
async function apiFetch(url, method='GET', body=null) {
  const opts = {method, headers:{'Content-Type':'application/json'}};
  if (body) opts.body = JSON.stringify(body);
  const r = await fetch(url, opts);
  return r.json();
}
</script>
</body>
</html>
